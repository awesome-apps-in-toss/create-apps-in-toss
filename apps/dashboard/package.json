{
  "name": "@barreleye/dashboard",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n vite,server -c cyan,yellow \"vite\" \"tsx --watch server/index.ts\"",
    "dev:ui": "vite",
    "dev:server": "tsx server/index.ts",
    "build": "tsc -b && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router": "^7.14.0"
  },
  "devDependencies": {
    "@barreleye/eslint-config": "workspace:*",
    "@barreleye/tsconfig": "workspace:*",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react-swc": "^3.7.2",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.7",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
